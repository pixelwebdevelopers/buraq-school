// ── Buraq School Database Schema ──
// Prisma schema for MySQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ── Enums ──

enum Role {
  ADMIN
  PRINCIPAL
  STAFF
}

// ── User ──

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  role      Role     @default(STAFF)
  branchId  Int?

  // Relations
  branch           Branch?   @relation("BranchStaff", fields: [branchId], references: [id], onDelete: SetNull)
  principalBranch  Branch?   @relation("BranchPrincipal")
  enrolledStudents Student[] @relation("EnrolledBy")
  receivedPayments Payment[] @relation("ReceivedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Branch ──

model Branch {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(150)
  address     String @db.VarChar(500)
  principalId Int?   @unique

  // Relations
  principal User? @relation("BranchPrincipal", fields: [principalId], references: [id], onDelete: SetNull)
  staff     User[]                  @relation("BranchStaff")
  students  Student[]
  families  Family[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("branches")
}

// ── Family (Family Tree) ──

model Family {
  id               Int     @id @default(autoincrement())
  fatherName       String  @db.VarChar(100)
  fatherPhone      String  @db.VarChar(20)
  fatherOccupation String? @db.VarChar(100)
  balance          Decimal @default(0) @db.Decimal(12, 2)
  branchId         Int

  // Relations
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  children Student[]
  payments Payment[]
  feeLogs  FeeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Father phone unique per branch (siblings detection)
  @@unique([fatherPhone, branchId])
  @@map("families")
}

// ── Student ──

model Student {
  id                Int      @id @default(autoincrement())
  admissionNo       String   @unique @db.VarChar(30)
  referenceNo       String?  @db.VarChar(30)
  name              String   @db.VarChar(100)
  dateOfBirth       String?  @db.VarChar(20)
  formBNicNo        String?  @db.VarChar(30)
  previousSchool    String?  @db.VarChar(150)
  caste             String?  @db.VarChar(50)
  religion          String?  @db.VarChar(50)
  gender            String?  @db.VarChar(10)
  classAdmitted     String?  @db.VarChar(30)
  referenceInSchool String?  @db.VarChar(100)
  specialInfo       String?  @db.Text

  // Father / Guardian info (also stored on family, but guardian may differ)
  guardianName     String? @db.VarChar(100)
  guardianRelation String? @db.VarChar(50)

  // Residential Address
  houseNo        String? @db.VarChar(20)
  streetNo       String? @db.VarChar(20)
  blockPhase     String? @db.VarChar(50)
  mohallahColony String? @db.VarChar(100)
  cell1          String? @db.VarChar(20)
  cell2          String? @db.VarChar(20)
  whatsapp       String? @db.VarChar(20)

  // Provision documents
  schoolLeavingCert Boolean @default(false)
  characterCert     Boolean @default(false)
  birthCert         Boolean @default(false)

  // Fee structure (per student)
  admissionFee  Decimal @default(0) @db.Decimal(10, 2)
  monthlyFee    Decimal @default(0) @db.Decimal(10, 2)
  annualCharges Decimal @default(0) @db.Decimal(10, 2)
  academyFee    Decimal @default(0) @db.Decimal(10, 2)
  labMiscFee    Decimal @default(0) @db.Decimal(10, 2)

  // Foreign keys
  branchId     Int
  familyId     Int
  enrolledById Int?

  // Relations
  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  family     Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  enrolledBy User?   @relation("EnrolledBy", fields: [enrolledById], references: [id], onDelete: SetNull)
  feeLogs    FeeLog[]

  admissionDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("students")
}

// ── Payment (per Family) ──

model Payment {
  id         Int      @id @default(autoincrement())
  familyId   Int
  amount     Decimal  @db.Decimal(12, 2)
  method     String?  @db.VarChar(30) // CASH, BANK, ONLINE, etc.
  remarks    String?  @db.Text
  receivedById Int?
  paidAt     DateTime @default(now())

  // Relations
  family     Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  receivedBy User?  @relation("ReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("payments")
}

// ── Fee Log (immutable audit trail) ──

model FeeLog {
  id          Int      @id @default(autoincrement())
  familyId    Int
  studentId   Int?
  amount      Decimal  @db.Decimal(12, 2)
  type        String   @db.VarChar(30) // MONTHLY, ADMISSION, ANNUAL, ACADEMY, LAB_MISC
  description String?  @db.VarChar(255)
  billedAt    DateTime @default(now())

  // Relations
  family  Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("fee_logs")
}
